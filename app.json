{
  "expo": {
    "name": "Jayam 360",
    "slug": "school-erp-mobile-app",
    "version": "1.0.4",
    "scheme": "schoolerp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sreejayam.schoolerp",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Jayam 360 uses your location to verify and record attendance at your school.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Jayam 360 uses your location to verify and record attendance at your school.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "leq3n23ynou6mjfaxg0v5tw9.82.29.165.177.sslip.io": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            }
          }
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.sreejayam.schoolerp",
      "versionCode": 1,
      "usesCleartextTraffic": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Jayam 360 uses your location to verify and record attendance at your school."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52f101db-59c6-47d6-89c3-567f54a48cf5"
      }
    },
    "owner": "jayam-school"
  }
}