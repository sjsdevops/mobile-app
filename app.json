{
  "expo": {
    "name": "school-erp-mobile-app",
    "slug": "school-erp-mobile-app",
    "version": "1.0.0",
    "scheme": "schoolerp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sreejayam.schoolerp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.sreejayam.schoolerp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#144FCC"
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "52f101db-59c6-47d6-89c3-567f54a48cf5"
      }
    },
    "owner": "jayam-school"
  }
}